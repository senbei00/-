          <span class="chev">⌄</span>
        </button>
        <div class="accordionBody">
          <div class="dataActions">
            <button id="backupBtn">バックアップ</button>
            <button id="resetBtn" class="danger">全データ削除</button>
          </div>
        </div>
      </section>
    </aside>
  </main>
</div>

<dialog id="shiftDialog">
  <form class="modal" method="dialog">
    <div class="modalHead">
      <h2 id="modalTitle">シフト追加</h2>
      <button type="button" id="closeDialog" class="iconBtn">×</button>
    </div>

    <input type="hidden" id="editIndex">
    <label>勤務先<select id="placeSelect"></select></label>

    <datalist id="timeOptions"></datalist>
    <div class="twoCol">
      <label>開始
        <input id="startTime" type="text" inputmode="numeric" maxlength="5" placeholder="09:00" list="timeOptions">
      </label>
      <label>終了
        <input id="endTime" type="text" inputmode="numeric" maxlength="5" placeholder="18:00" list="timeOptions">
      </label>
    </div>

    <label>休憩時間（分）<input id="breakMinutes" type="number" min="0" step="5" value="0"></label>
    <label>メモ<input id="memo" type="text" placeholder="任意入力"></label>

    <div class="copyActions">
      <button type="button" id="openPresetPicker">よく使う時間</button>
      <button type="button" id="openHistoryPicker">履歴からコピー</button>
    </div>
    <div class="copyActions one">
      <button type="button" id="saveAsPreset">この時間を固定</button>
    </div>

    <div class="calcBox"><span>計算</span><b id="calcWork">0時間0分</b></div>

    <div class="actions">
      <button type="button" id="deleteShift" class="danger">削除</button>
      <button type="button" id="saveShift" class="primary">保存</button>
    </div>
  </form>
</dialog>

<dialog id="historyDialog">
  <form class="modal wideModal" method="dialog">
    <div class="modalHead">
      <h2>履歴からコピー</h2>
      <button type="button" id="closeHistory" class="iconBtn">×</button>
    </div>
    <div id="historyList" class="pickerList"></div>
  </form>
</dialog>

<dialog id="presetDialog">
  <form class="modal wideModal" method="dialog">
    <div class="modalHead">
      <h2>よく使う時間</h2>
      <button type="button" id="closePreset" class="iconBtn">×</button>
    </div>
    <div id="presetList" class="pickerList"></div>
  </form>
</dialog>

<script src="app.js"></script>
</body>
</html>
